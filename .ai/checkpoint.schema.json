{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "checkpoint.schema.json",
  "title": "EBTA multi-AI relay checkpoint",
  "description": "v1.2.0 — macro governance only. Runtime state lives exclusively in tracking.json.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "checkpoint_kind",
    "updated_at",
    "status",
    "repo",
    "relay_contract",
    "active_paths",
    "authority_model",
    "active_workstream_id",
    "next_actions",
    "workstreams",
    "validation",
    "session_log",
    "risks"
  ],
  "properties": {
    "schema_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "checkpoint_kind": { "const": "multi_ai_relay" },
    "updated_at": { "type": "string", "format": "date" },
    "status": { "enum": ["ACTIVE", "PAUSED", "COMPLETE", "BLOCKED"] },
    "repo": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "root", "git_head_short", "git_status_policy", "warning"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "root": { "type": "string", "minLength": 1 },
        "git_head_short": { "type": "string", "minLength": 1 },
        "git_status_policy": { "type": "string", "minLength": 1 },
        "warning": { "type": "string" }
      }
    },
    "relay_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["only_files", "write_policy", "startup_read_order", "do_not_create"],
      "properties": {
        "only_files": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1,
          "uniqueItems": true
        },
        "write_policy": { "enum": ["overwrite_only"] },
        "startup_read_order": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 5,
          "uniqueItems": true
        },
        "do_not_create": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        }
      }
    },
    "active_paths": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "active_hook_path",
        "active_tracking_path",
        "active_protocol_entrypoint",
        "human_start_path",
        "backlog_mainline_path",
        "backlog_annexes_path",
        "backlog_fixes_path"
      ],
      "properties": {
        "active_hook_path": { "type": "string", "minLength": 1 },
        "active_tracking_path": { "type": "string", "minLength": 1 },
        "active_protocol_entrypoint": { "type": "string", "minLength": 1 },
        "human_start_path": { "type": "string", "minLength": 1 },
        "backlog_mainline_path": { "type": "string", "minLength": 1 },
        "backlog_annexes_path": { "type": "string", "minLength": 1 },
        "backlog_fixes_path": { "type": "string", "minLength": 1 }
      }
    },
    "authority_model": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "normative_authority",
        "runtime_authority",
        "runtime_hook",
        "runtime_machine_state",
        "runtime_history",
        "agent_bootstrap",
        "ai_cockpit",
        "tooling_support",
        "codex_adapter",
        "adapter_boundary"
      ],
      "properties": {
        "normative_authority": { "type": "string", "minLength": 1 },
        "runtime_authority": { "type": "string", "minLength": 1 },
        "runtime_hook": { "type": "string", "minLength": 1 },
        "runtime_machine_state": { "type": "string", "minLength": 1 },
        "runtime_history": { "type": "string", "minLength": 1 },
        "agent_bootstrap": { "type": "string", "minLength": 1 },
        "ai_cockpit": { "type": "string", "minLength": 1 },
        "tooling_support": { "type": "string", "minLength": 1 },
        "codex_adapter": { "type": "string", "minLength": 1 },
        "adapter_boundary": { "type": "string", "minLength": 1 }
      }
    },
    "active_workstream_id": {
      "type": ["string", "null"],
      "description": "ID of the currently active workstream. Null when nothing is active. Single source of truth — no duplication of workstream fields here."
    },
    "next_actions": {
      "type": "array",
      "items": { "$ref": "#/$defs/action_item" }
    },
    "workstreams": {
      "type": "array",
      "items": { "$ref": "#/$defs/workstream" },
      "uniqueItems": true
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["commands"],
      "properties": {
        "commands": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["command", "purpose", "last_result"],
            "properties": {
              "command": { "type": "string", "minLength": 1 },
              "purpose": { "type": "string", "minLength": 1 },
              "last_result": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    },
    "session_log": {
      "type": "array",
      "description": "Rolling log of the last 5 sessions. Reset each new session; never accumulate unboundedly.",
      "maxItems": 5,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["date", "summary", "files_count"],
        "properties": {
          "date": { "type": "string", "format": "date" },
          "summary": { "type": "string", "minLength": 1 },
          "files_count": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "status", "risk", "control"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "status": { "enum": ["OPEN", "CONTROLLED", "DEFERRED", "CLOSED"] },
          "risk": { "type": "string", "minLength": 1 },
          "control": { "type": "string", "minLength": 1 }
        }
      }
    }
  },
  "$defs": {
    "action_item": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "status", "title", "classification", "non_goals"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "status": { "enum": ["TODO", "PENDING", "ACTIVE", "DONE", "DEFERRED", "BLOCKED"] },
        "title": { "type": "string", "minLength": 1 },
        "classification": { "$ref": "#/$defs/classification" },
        "non_goals": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        }
      }
    },
    "workstream": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "track",
        "status",
        "lifecycle",
        "classification",
        "source_path",
        "active_runtime_path",
        "opened_at",
        "last_moved_at",
        "routing_decision",
        "routing_reason",
        "moved_by",
        "blocks_mainline",
        "advances_mainline",
        "closure_reason",
        "non_goals"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "priority": {
          "type": "integer",
          "minimum": 1,
          "maximum": 3,
          "description": "1=critical blocks mainline, 2=important, 3=optional. Absent means unranked."
        },
        "is_active": {
          "type": "boolean",
          "description": "True on the workstream currently being executed. At most one workstream has is_active=true at a time."
        },
        "track": { "enum": ["mainline", "annexe", "fix"] },
        "status": { "enum": ["TODO", "PENDING", "ACTIVE", "DONE", "DEFERRED", "BLOCKED"] },
        "lifecycle": {
          "enum": [
            "INTAKE",
            "TRIAGED",
            "PLANNED",
            "ACTIVE",
            "BLOCKED",
            "DONE",
            "REJECTED",
            "SUPERSEDED",
            "ARCHIVED"
          ]
        },
        "classification": { "$ref": "#/$defs/classification" },
        "source_path": { "type": "string", "minLength": 1 },
        "original_draft_path": {
          "type": ["string", "null"],
          "description": "Path to the raw human draft as archived under '0 - HUMAN START HERE/archive/' at promotion time. Null if this workstream was authored directly in the backlog without a prior human draft. Kept for traceability: source_path points to the AI-rewritten plan, this field points to the untouched original."
        },
        "active_runtime_path": {
          "type": ["string", "null"],
          "minLength": 1
        },
        "opened_at": { "type": "string", "format": "date" },
        "last_moved_at": { "type": "string", "format": "date" },
        "routing_decision": { "enum": ["mainline", "annexe", "fix", "rejected", "deferred"] },
        "routing_reason": { "type": "string", "minLength": 1 },
        "moved_by": { "enum": ["human", "ai", "mixed"] },
        "blocks_mainline": { "type": "boolean" },
        "advances_mainline": { "type": "boolean" },
        "closure_reason": { "type": ["string", "null"] },
        "non_goals": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        }
      }
    },
    "classification": {
      "enum": [
        "GOVERNANCE",
        "IMPLEMENTATION_DETAIL",
        "CONTRACT_ENCODING",
        "TEST_FIXTURE",
        "ADAPTER_MAPPING",
        "DOCUMENTATION_CLARIFICATION_NEEDED",
        "NORMATIVE_CHANGE_REQUIRED"
      ]
    }
  }
}
