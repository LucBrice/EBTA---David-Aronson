{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ebta.local/schemas/config.schema.json",
  "title": "EBTA preregistered configuration",
  "schema_version": "1.0.0",
  "x_normative_source": "Protocole/PAQUET D'EXECUTION EBTA.md section 3.1; Protocole/TEMPLATE - Configuration préenregistrée d'une recherche EBTA.md",
  "x_translation_type": "CONTRACT_ENCODING",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "config_id",
    "project_id",
    "research_family_id",
    "hypothesis_id",
    "process_version_id",
    "protocol_version",
    "data_snapshots",
    "walk_forward_schedule",
    "candidate_space",
    "selection_rule",
    "statistical_plan",
    "execution_model",
    "robustness_plan",
    "oos_opening_gate",
    "incubation_plan",
    "reproducibility_manifest",
    "document_hash"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "config_id": { "type": "string" },
    "project_id": { "type": "string" },
    "research_family_id": { "type": "string" },
    "hypothesis_id": { "type": "string" },
    "process_version_id": { "type": "string" },
    "protocol_version": { "type": "string", "enum": ["EBTA-DOC-1.0"] },
    "data_snapshots": { "type": "array", "minItems": 1, "items": { "type": "object" } },
    "walk_forward_schedule": { "type": "array", "minItems": 1, "items": { "type": "object" } },
    "candidate_space": { "type": "object" },
    "selection_rule": { "type": "object" },
    "statistical_plan": { "type": "object" },
    "execution_model": { "type": "object" },
    "robustness_plan": { "type": "object" },
    "oos_opening_gate": { "type": "object" },
    "incubation_plan": { "type": "object" },
    "reproducibility_manifest": { "type": "object" },
    "document_hash": { "type": "string" }
  }
}
