{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ebta.local/schemas/methodological_derogation.schema.json",
  "title": "EBTA G-BIAS methodological derogation",
  "schema_version": "1.0.0",
  "x_normative_source": "Protocole/SOP 13 - Gouvernance des biais humains et incidents méthodologiques.md; Protocole/TEMPLATE - Dérogation méthodologique EBTA.md",
  "x_translation_type": "CONTRACT_ENCODING",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "derogation_id",
    "timestamp",
    "project_id",
    "research_family_id",
    "phase",
    "affected_decision",
    "justification",
    "approved_by",
    "approval_timestamp",
    "non_repair_confirmed",
    "status"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "derogation_id": { "type": "string" },
    "timestamp": { "type": "string" },
    "project_id": { "type": "string" },
    "research_family_id": { "type": "string" },
    "phase": {
      "type": "string",
      "enum": ["TRAIN", "TEST", "TEST_PRE_OOS", "PRE_OOS", "OOS", "POST_OOS", "LIVE"]
    },
    "affected_decision": { "type": "string" },
    "justification": { "type": "string" },
    "approved_by": { "type": "string" },
    "approval_timestamp": { "type": "string" },
    "non_repair_confirmed": { "type": "boolean" },
    "status": {
      "type": "string",
      "enum": ["APPROVED", "REJECTED", "SUPERSEDED"]
    }
  }
}
