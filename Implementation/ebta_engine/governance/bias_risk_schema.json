{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ebta.local/schemas/bias_risk.schema.json",
  "title": "EBTA G-BIAS risk registry entry",
  "schema_version": "1.0.0",
  "x_normative_source": "Protocole/SOP 13 - Gouvernance des biais humains et incidents methodologiques.md; Protocole/BIAS_RISK_REGISTER.md",
  "x_translation_type": "CONTRACT_ENCODING",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "bias_id",
    "name",
    "description",
    "phase",
    "default_severity",
    "detectors",
    "controlled_artifacts",
    "impacted_gates",
    "corrective_procedure",
    "sop_reference"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "bias_id": { "type": "string" },
    "name": { "type": "string" },
    "description": { "type": "string" },
    "phase": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": ["TRAIN", "TEST", "PRE_OOS", "OOS", "POST_OOS", "LIVE"]
      }
    },
    "default_severity": {
      "type": "string",
      "enum": ["LEVEL_0", "LEVEL_1", "LEVEL_2", "LEVEL_3", "LEVEL_4", "LEVEL_5"]
    },
    "detectors": { "type": "array", "items": { "type": "string" } },
    "controlled_artifacts": { "type": "array", "items": { "type": "string" } },
    "impacted_gates": { "type": "array", "items": { "type": "string" } },
    "corrective_procedure": { "type": "string" },
    "sop_reference": { "type": "string" }
  }
}
